CLAN_MEMBER_ROLE_ID=YOUR_ROLE_ID #ID OF THE ROLE TO ASSIGN THROUGH VALIDATED APPLICATION = DEVELOPER MODE -> RIGHT CLICK -> ROLE ID
STAFF_APPLICATION_FORUM_ID=YOUR_FORUM_CHANNEL_ID #ID OF THE CHANNEL TO POST APPLICATIONS = DEVELOPER MODE -> RIGHT CLICK -> CHANNEL ID
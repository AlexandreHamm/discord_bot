DISCORD_TOKEN=DISCORD_BOT_TOKEN #https://discord.com/developers/applications/ -> BOT -> TOKEN
DISCORD_CLIENT_ID=APPLICATION_ID #https://discord.com/developers/applications/ -> GENERAL INFORMATION -> APPLICATION ID
